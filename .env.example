# ═══════════════════════════════════════════
# AERO-CLUB BAR — Variables d'environnement
# ═══════════════════════════════════════════
# Copiez ce fichier en .env.local et remplissez les valeurs

# ─── SumUp API ───
# 1. Allez sur https://developer.sumup.com
# 2. Créez une application
# 3. Récupérez votre API Key et Merchant Code
SUMUP_API_KEY=votre_cle_api_sumup
SUMUP_MERCHANT_CODE=votre_merchant_code

# ─── URL publique du site (pour les redirections SumUp) ───
# En local: http://localhost:3000
# En prod: https://votre-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Admin PIN (optionnel, défaut: 1234) ───
ADMIN_PIN=1234
